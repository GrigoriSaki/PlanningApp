@using PlanningApp.Services
@using PlanningApp.Models
@using PlanningApp.Planning
@using System.Globalization;

@page "/planning"
@inject PlanningService PlanningService
@inject EmployeeService EmployeeService
@inject ProductionLineService ProductionLineService
@inject IJSRuntime JS

<PageTitle>Planning</PageTitle>

@code {
	private DateTime selectedWeek = DateTime.Today;
	private List<ScheduleAssignment> assignments = new();
	private List<Employee> employees = new();
	private List<ProductionLine> productionLines = new();
	private DateTime monday;
	private PlanningCell? selectedCell;
	private bool isPopupVisible = false;
	private double mouseX;
	private double mouseY;
	private bool showSecondShift = false;
	private string? errorMessage;

	protected override async Task OnInitializedAsync()
	{
		employees = await EmployeeService.GetAllAsync();

		productionLines = await ProductionLineService.GetAllAsync();

		await LoadWeek();
	}
	private DateTime GetStartOfWeek(DateTime date)
	{
		int diff = (7 + (date.DayOfWeek - DayOfWeek.Monday)) % 7;
		return date.AddDays(-diff).Date;
	}

	private List<DateTime> WeekDays =>
[
	monday,
	monday.AddDays(1),
	monday.AddDays(2),
	monday.AddDays(3),
	monday.AddDays(4),
	monday.AddDays(5),
	monday.AddDays(6)
];

	private ScheduleAssignment? GetAssignment(
		DateTime day,
		int shift,
		int productionLineId,
		string position)
	{
		return assignments.FirstOrDefault(x =>
			x.WorkDate.Date == day.Date &&
			x.Shift == shift &&
			x.ProductionLineId == productionLineId &&
			x.PositionOnLine == position);
	}

	private void SelectCell(
	MouseEventArgs e,
	DateTime day,
	int shift,
	int lineId,
	string position)
	{
		selectedCell = new PlanningCell
		{
			WorkDate = day,
			Shift = shift,
			ProductionLineId = lineId,
			Position = position
		};

		mouseX = e.ClientX + 10;
		mouseY = e.ClientY + 10;

		isPopupVisible = true;
	}

	private void ClosePopup()
	{
		isPopupVisible = false;
		errorMessage = null;
	}

	private async Task AssignEmployee(int employeeId)
	{
		if (selectedCell == null)
			return;

		bool result = await PlanningService.AssignEmployeeAsync(
		selectedCell.WorkDate,
		selectedCell.Shift,
		selectedCell.ProductionLineId,
		selectedCell.Position,
		employeeId);

		if (!result)
		{
			errorMessage = "Employee is already assigned to another shift on this day.";
			return;
		}

		assignments = await PlanningService.GetWeekPlanningAsync(selectedWeek);
		selectedCell = null;
		ClosePopup();
	}

	private async Task  UnassignEmployeeAsync()
	{
		if (selectedCell == null)
			return;

		await PlanningService.UnassignEmployeeAsync(
				selectedCell.WorkDate,
				selectedCell.Shift,
				selectedCell.ProductionLineId,
				selectedCell.Position);

		assignments = await PlanningService.GetWeekPlanningAsync(selectedWeek);
		selectedCell = null;
		ClosePopup();
	}

	private async Task LoadWeek()
	{
		monday = GetStartOfWeek(selectedWeek);
		assignments = await PlanningService.GetWeekPlanningAsync(selectedWeek);
		showSecondShift = assignments.Any(x => x.Shift == 2);
	}

	private async Task PreviousWeek()
	{
		selectedWeek = selectedWeek.AddDays(-7);
		await LoadWeek();
	}
	private async Task NextWeek()
	{
		selectedWeek = selectedWeek.AddDays(+7);
		await LoadWeek();
	}
	private void ShowSecondShift()
	{
		showSecondShift = true;
	}
	private async Task CopyToNextWeek()
	{
		bool confirm = await JS.InvokeAsync<bool>(
	  "confirm",
	  "Are you sure you want to copy this schedule to next week?"
  );

		if (!confirm)
			return;

		bool success = await PlanningService.CopyToNextWeekAsync(selectedWeek);

		if (!success)
		{
			await JS.InvokeAsync<bool>(
				"confirm",
				"Next week already contains schedule."
			);

			return;
		}

		await LoadWeek();
	}

	
}

<div class="container-fluid px-4 pt-2">
	<h1 class="fw-bold text-dark mb-2">Planning</h1>
	<div class="d-flex align-items-center gap-2">
		<h5 class="text-dark mb-0 me-2">Week:</h5>
		<button type="button"
				class="btn btn-sm d-flex align-items-center justify-content-center"
				style="background-color: #dbf0ee; color: #115e59; border: 1px solid #a6d9d5; width: 28px; height: 28px; padding: 0;"
				@onclick="PreviousWeek">
			<i class="bi bi-chevron-left"></i>
		</button>
		<h5 class="text-dark mb-0">@monday.ToString("dd.MM.yyyy") - @monday.AddDays(6).ToString("dd.MM.yyyy")</h5>
		<button type="button"
				class="btn btn-sm d-flex align-items-center justify-content-center"
				style="background-color: #dbf0ee; color: #115e59; border: 1px solid #a6d9d5; width: 28px; height: 28px; padding: 0;"
				@onclick="NextWeek">
			<i class="bi bi-chevron-right"></i>
		</button>
		<button type="button"
				class="btn btn-link text-decoration-underline p-0 d-inline-flex align-items-center gap-2 ms-2"
				style="color: #115e59; font-weight: 500; font-size: 0.95rem;" @onclick="CopyToNextWeek">
			 Copy to next week 
		</button>
	</div>

	@foreach (var line in productionLines)
	{
		if (line.IsActive == true)
		{
			<h3>line: @line.Name</h3>
			<table class="table table-bordered table-hover">
				<thead>
					<tr>
						<th style="width: 200px;">Position</th>

						@foreach (var day in WeekDays)
						{
							<th>
								@day.ToString("ddd", CultureInfo.GetCultureInfo("en-US"))
								<br />
								<span class="fw-light text-muted" style="font-size: 0.95rem;">
									@day.ToString("dd.MM")
								</span>
							</th>
						}
					</tr>
				</thead>
				<tbody>
					@foreach (var position in PlanningPositions.All)
					{
						<tr>
							<th scope="row">@position</th>

							@foreach (var day in WeekDays)
							{
								var currentDay = day;
								var assignment = GetAssignment(day, 1, line.Id, position);
								<td @onclick="(e) => SelectCell(e, currentDay, 1, line.Id, position)" style="cursor: pointer;"
									class="position-relative @(assignment != null ? "assigned" : "")">

									@if (assignment != null)
									{
										@assignment.Employee.FirstName
									}
									else
									{
										<span class="text-muted">&nbsp;</span>
									}
								</td>
							}
						</tr>
					}
				</tbody>
			</table>
		}
	}
	@if (showSecondShift)
	{
		<div class="d-flex justify-content-center align-items-center" style="height: 100px;">
			<h3>Shift 2</h3>
		</div>
		@foreach (var line in productionLines)
		{
			if (line.IsActive == true)
			{

				<h3>line: @line.Name</h3>
				<table class="table table-bordered table-hover">
					<thead>
						<tr>
							<th style="width: 200px;">Position</th>

							@foreach (var day in WeekDays)
							{
								<th>
									@day.ToString("ddd", CultureInfo.GetCultureInfo("en-US"))
									<br />
									<span class="fw-light text-muted" style="font-size: 0.95rem;">
										@day.ToString("dd.MM")
									</span>
								</th>
							}
						</tr>
					</thead>
					<tbody>
						@foreach (var position in PlanningPositions.All)
						{
							<tr>
								<th scope="row">@position</th>

								@foreach (var day in WeekDays)
								{
									var currentDay = day;
									var assignment = GetAssignment(day, 2, line.Id, position);
									<td @onclick="(e) => SelectCell(e, currentDay, 2, line.Id, position)" style="cursor: pointer;"
										class="position-relative @(assignment != null ? "assigned" : "")">

										@if (assignment != null)
										{
											@assignment.Employee.FirstName
										}
										else
										{
											<span class="text-muted">&nbsp;</span>
										}
									</td>
								}
							</tr>
						}
					</tbody>
				</table>
			}
		}
	}
	<div class="d-flex justify-content-center align-items-center" style="height: 100px;">
		@if (!showSecondShift && productionLines.Any(x => x.IsActive))
		{
			<button type="button" class="btn btn-primary ms-2" @onclick="()=>ShowSecondShift()">
				+ Add Shift
			</button>
		}
		
		@if (!productionLines.Any(x => x.IsActive))
		{
			<div class="alert alert-info d-flex align-items-center" role="alert">
				<span class="fs-5 me-3">ℹ️</span>
				<div>
					No lines to display. Add a new line to get started.
				</div>
			</div>
		}
	</div>
	@if (isPopupVisible)
	{
		<div @onclick="ClosePopup"
			 style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 1040; background: transparent;">
		</div>
		<div class="card shadow-sm position-fixed" style="top: @(mouseY)px; left: @(mouseX)px; z-index: 1050; min-width: 200px;">
			<div class="card-header d-flex justify-content-between align-items-center py-1 bg-light">
				<div class="d-flex align-items-center gap-2 small">
					<strong>@selectedCell.Position</strong>
					<span class="text-muted">|</span>
					<div>@selectedCell.WorkDate.ToString("dddd dd.MM")</div>
					<span class="text-muted">|</span>
					<div>Shift @selectedCell.Shift</div>
				</div>
				<button type="button" class="btn-close ms-3" style="font-size: 0.75rem;" @onclick="ClosePopup"></button>
			</div>
			<div class="list-group list-group-flush small" style="max-height: 200px; overflow-y: auto;">

				@if (errorMessage != null)
				{
					<div class="alert alert-warning m-2 p-2">
						@errorMessage
					</div>
				}

				@if (GetAssignment(
					selectedCell.WorkDate,
					selectedCell.Shift,
					selectedCell.ProductionLineId,
					selectedCell.Position) != null)
				{
					<button class="btn btn-danger" @onclick="()=>UnassignEmployeeAsync()">
						Unassign
					</button>				
				}

				@foreach (var employee in employees)
					if (employee.IsActive == true)
					{
						{
							<button type="button"
									class="list-group-item list-group-item-action py-1 px-2"
									@onclick="() => AssignEmployee(employee.Id)">
								@employee.FirstName @employee.LastName
							</button>
						}
					}
			</div>
		</div>
	}
</div>
