@page "/dashboard"

<PageTitle>Dashboard</PageTitle>

<div class="container-fluid px-4 mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold text-dark m-0">Dashboard</h1>
            <p class="text-muted m-0">Welcome to the production planning dashboard.</p>
        </div>
        <span class="badge rounded-pill px-3 py-2" style="background-color: #e0f2f1; color: #0f766e; font-weight: 600;">Today</span>
    </div>

    <div class="row g-3 mb-5">

        <div class="col-12 col-sm-6 col-md-3">
            <div class="card h-100 border-0 shadow-sm p-3" style="border-radius: 16px; background-color: #ffffff;">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span class="fw-semibold text-muted" style="font-size: 0.95rem;">Employees</span>
                    <span class="fs-5" style="color: #0f766e;">👥</span>
                </div>
                <div class="fs-1 fw-bold text-dark lh-1 mb-1">12</div>
                <div class="text-muted small">Active employees</div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-md-3">
            <div class="card h-100 border-0 shadow-sm p-3" style="border-radius: 16px; background-color: #ffffff;">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span class="fw-semibold text-muted" style="font-size: 0.95rem;">Lines</span>
                    <span class="fs-5" style="color: #0f766e;">⚙️</span>
                </div>
                <div class="fs-1 fw-bold text-dark lh-1 mb-1">0</div>
                <div class="text-muted small">Production lines</div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-md-3">
            <div class="card h-100 border-0 shadow-sm p-3" style="border-radius: 16px; background-color: #ffffff;">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span class="fw-semibold text-muted" style="font-size: 0.95rem;">Today's shift</span>
                    <span class="fs-5" style="color: #0f766e;">🗓️</span>
                </div>
                <div class="fs-1 fw-bold text-dark lh-1 mb-1">0</div>
                <div class="text-muted small">Assignments</div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-md-3">
            <div class="card h-100 border-0 shadow-sm p-3" style="border-radius: 16px; background-color: #ffffff;">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span class="fw-semibold text-muted" style="font-size: 0.95rem;">Alerts</span>
                    <span class="fs-5 text-danger">⚠️</span>
                </div>
                <div class="fs-1 fw-bold text-danger lh-1 mb-1">0</div>
                <div class="text-muted small">Missing positions</div>
            </div>
        </div>

    </div>

</div>

